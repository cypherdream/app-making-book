# Copy this file to .env and fill in real values. Never commit .env.

DATABASE_URL="postgresql://user:password@localhost:5432/app_making_book"
PORT=3000
CLIENT_ORIGIN="http://localhost:5173"
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-value"
# Only set during a secret rotation window — see backend/src/config/secrets.ts
JWT_SECRET_PREVIOUS=

# --- Optional: Redis cache (free tier: Upstash, 10k commands/day, no card) ---
# Leave blank and the app works identically, just without caching.
REDIS_URL=

# --- Optional: Web Push notifications (free, self-hosted) ---
# Generate with: npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:you@example.com"

# --- Optional: Stripe payments ---
# Requires a free Stripe account (test mode needs no business verification).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Optional: error monitoring ---
# If set, wire this into a Sentry-compatible SDK call in errorHandler.ts.
# Leaving it blank means errors just log to the console, same as today.
SENTRY_DSN=

# --- Optional: Email (verification, password reset) ---
# Free tier: Resend, 3,000 emails/month (100/day cap), no card needed.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# --- Optional: Prometheus-format metrics at /metrics ---
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
METRICS_TOKEN=

# --- Optional: App Builder prompt interpretation ---
# Free tier: Groq (console.groq.com), no credit card, ~30 req/min.
GROQ_API_KEY=
